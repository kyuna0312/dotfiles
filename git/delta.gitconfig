[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = Catppuccin-mocha
    plus-style = syntax "#a6e3a1"
    minus-style = syntax "#f38ba8"
    hunk-header-style = file line-number syntax "#b4befe"
    file-style = bold "#89dceb"

[merge]
    conflictstyle = diff3
