[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = Catppuccin-mocha
    plus-style = syntax "#9dffcc"
    minus-style = syntax "#ff4d8d"
    hunk-header-style = file line-number syntax "#c8a5ff"
    file-style = bold "#00e5ff"

[merge]
    conflictstyle = diff3
